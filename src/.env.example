APP_NAME="Portfolio UTS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE='Asia/Jakarta'
APP_URL=https://uts.test
ASSET_URL=https://uts.test
DEBUGBAR_ENABLED=false
ASSET_PREFIX=

# Application Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file

# PHP Configuration
PHP_CLI_SERVER_WORKERS=4

# Password Hashing
# Options: 'bcrypt', 'argon', 'argon2id'
BCRYPT_ROUNDS=12

# Logging Configuration
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
# Database Name
DB_DATABASE=uts_db
# Default: root
DB_USERNAME=root
# Default: root
DB_PASSWORD=root

# ==========================================
# SESSION CONFIGURATION
# ==========================================
# Options: 'file', 'cookie', 'database', 'memcached', 'redis'
SESSION_DRIVER=database
# Session lifetime in minutes
SESSION_LIFETIME=120
# Encrypt session data
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ==========================================
# BROADCAST & FILESYSTEM
# ==========================================
# Options: 'log', 'pusher', 'redis'
BROADCAST_CONNECTION=log
# Default filesystem: 'local' (storage/app)
FILESYSTEM_DISK=local

# ==========================================
# QUEUE CONFIGURATION
# ==========================================
# Options: 'sync', 'database', 'beanstalkd', 'sqs', 'redis'
QUEUE_CONNECTION=database

# ==========================================
# CACHE CONFIGURATION
# ==========================================
# Options: 'file', 'memcached', 'redis', 'database'
CACHE_STORE=database
# Cache key prefix
# CACHE_PREFIX=

# Memcached configuration
MEMCACHED_HOST=127.0.0.1

# ==========================================
# REDIS CONFIGURATION
# ==========================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================
# MAIL CONFIGURATION
# ==========================================
# Options: 'smtp', 'sendmail', 'mailgun', 'ses', 'postmark', 'log'
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Sender email address
MAIL_FROM_ADDRESS="hello@example.com"
# Sender name
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# AWS S3 CONFIGURATION (Optional)
# ==========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==========================================
# VITE & BUILD
# ==========================================
VITE_APP_NAME="${APP_NAME}"
